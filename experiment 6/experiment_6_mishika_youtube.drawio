        <mxCell id="p2-e5" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="&lt;b&gt;Comment&lt;/b&gt;  { commentId, userId, videoId, text, timestamp }" vertex="1">
          <mxGeometry height="25" width="390" x="90" y="428" as="geometry" />
