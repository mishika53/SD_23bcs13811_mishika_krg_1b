          <mxGeometry height="25" width="540" x="590" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p4-dash1" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• Video split into .mp4 or .m4s segments (2–6 sec each)" vertex="1">
