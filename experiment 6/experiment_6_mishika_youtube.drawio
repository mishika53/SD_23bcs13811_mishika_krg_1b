  <diagram name="Step 1 - Requirements" id="page-01">
    <mxGraphModel dx="1028" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p1-title" parent="1" style="text;html=1;align=center;fontSize=20;strokeColor=none;fillColor=none;fontColor=#1a1a1a;" value="&lt;b&gt;YouTube App — System Design&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="700" x="200" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p1-step" parent="1" style="text;html=1;align=center;fontSize=13;strokeColor=none;fillColor=none;fontColor=#666666;" value="Step 1 of 6: Requirements Gathering" vertex="1">
          <mxGeometry height="25" width="700" x="200" y="58" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="420" width="440" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr-title" parent="1" style="text;html=1;align=center;fontSize=14;strokeColor=none;fillColor=none;" value="&lt;b&gt;Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="390" x="80" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr1" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="1. Users can Register / Login." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr2" parent="1" style="text;html=1;align=left;fontSize=12;" value="2. Users can Upload videos." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="190" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr3" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="3. Users can Stream / Watch videos." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr4" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="4. Adaptive Streaming: HLS / DASH protocol." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="250" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr5" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="5. Dynamic Bandwidth: auto-switch 1080p / 720p / 360p." vertex="1">
          <mxGeometry height="25" width="400" x="90" y="280" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr6" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="6. Users can Like / Dislike a video." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="310" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr7" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="7. Users can Post / View / Delete Comments." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="340" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr8" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="8. Users can Subscribe to Channels." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="370" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr9" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="9. Search videos by title / tag / channel." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="400" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr10" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="10. Recommended / trending feed." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="430" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr11" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=2;" value="Core Requirement: Video must stream smoothly" vertex="1">
          <mxGeometry height="25" width="390" x="90" y="480" as="geometry" />
        </mxCell>
        <mxCell id="p1-fr12" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=2;" value="with automatic quality adjustments based on bandwidth." vertex="1">
          <mxGeometry height="25" width="390" x="90" y="503" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="420" width="460" x="560" y="110" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr-title" parent="1" style="text;html=1;align=center;fontSize=14;strokeColor=none;fillColor=none;" value="&lt;b&gt;&amp;nbsp;Non-Functional Requirements&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="440" x="570" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr1" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="1. Scale: 2 Billion users worldwide." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr2" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="   → 500 hours of video uploaded every minute." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="185" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr3" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="   → ~1 Billion video views per day." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="210" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr4" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="2. CAP Theorem: Availability &gt;&gt; Consistency (AP System)." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="250" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr5" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="   → Likes/Comments: eventual consistency OK." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="275" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr6" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="3. Low Latency: &lt; 2 sec buffering for video start." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="315" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr7" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="4. Storage: ~1 Exabyte scale (raw + all resolutions)." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="345" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr8" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="5. Reliability: No video data loss." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="375" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr9" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="6. Global CDN: Serve videos from edge nodes near users." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="405" as="geometry" />
        </mxCell>
        <mxCell id="p1-nfr10" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="7. Read-Heavy System: reads &gt;&gt; writes (100:1 ratio)." vertex="1">
          <mxGeometry height="25" width="420" x="580" y="435" as="geometry" />
        </mxCell>
        <mxCell id="p1-est-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="200" width="960" x="60" y="560" as="geometry" />
        </mxCell>
        <mxCell id="p1-est-title" parent="1" style="text;html=1;align=center;fontSize=14;strokeColor=none;fillColor=none;" value="&lt;b&gt;Capacity Estimation&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="940" x="70" y="570" as="geometry" />
        </mxCell>
        <mxCell id="p1-est1" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="Uploads: 500 hrs/min × 60 min × 24 hrs = 720,000 hrs of video/day" vertex="1">
          <mxGeometry height="25" width="600" x="80" y="610" as="geometry" />
        </mxCell>
        <mxCell id="p1-est2" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="Storage per hour (all qualities): ~10 GB → 720,000 × 10 GB = ~7 PB/day new storage" vertex="1">
          <mxGeometry height="25" width="700" x="80" y="640" as="geometry" />
        </mxCell>
        <mxCell id="p1-est3" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="Bandwidth: 1B views/day × avg 5 MB/view = 5 PB/day outgoing bandwidth" vertex="1">
          <mxGeometry height="25" width="650" x="80" y="670" as="geometry" />
        </mxCell>
        <mxCell id="p1-est4" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="Read QPS: 1B views / 86400 sec ≈ ~11,500 video stream requests/sec" vertex="1">
          <mxGeometry height="25" width="650" x="80" y="700" as="geometry" />
        </mxCell>
        <mxCell id="p1-est5" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="Write QPS (uploads): 500 hr/min = ~8 videos/sec uploaded" vertex="1">
          <mxGeometry height="25" width="600" x="80" y="730" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Step 2 - Entities and APIs" id="page-02">
    <mxGraphModel dx="1028" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
