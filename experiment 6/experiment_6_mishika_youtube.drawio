        <mxCell id="p2-e2" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="&lt;b&gt;Video&lt;/b&gt;  { videoId, uploaderId, title, description}" vertex="1">
