        <mxCell id="p2-title" parent="1" style="text;html=1;align=center;fontSize=20;strokeColor=none;fillColor=none;" value="&lt;b&gt;YouTube App — System Design&lt;/b&gt;" vertex="1">
          <mxGeometry height="40" width="700" x="200" y="20" as="geometry" />
        </mxCell>
        <mxCell id="p2-step" parent="1" style="text;html=1;align=center;fontSize=13;strokeColor=none;fillColor=none;fontColor=#666666;" value="Step 2 of 6: Major Entities &amp; API Endpoints" vertex="1">
          <mxGeometry height="25" width="700" x="200" y="58" as="geometry" />
