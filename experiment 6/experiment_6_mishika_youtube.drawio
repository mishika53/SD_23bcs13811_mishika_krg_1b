  <diagram name="Step 3 - Upload and Encoding Pipeline" id="page-03">
    <mxGraphModel dx="1371" dy="815" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p3-title" parent="1" style="text;html=1;align=center;fontSize=20;strokeColor=none;fillColor=none;" value="&lt;b&gt;YouTube App — System Design&lt;/b&gt;" vertex="1">
          <mxGeometry height="35" width="700" x="250" y="15" as="geometry" />
        </mxCell>
        <mxCell id="p3-step" parent="1" style="text;html=1;align=center;fontSize=13;strokeColor=none;fillColor=none;fontColor=#666666;" value="Step 3 of 6: Video Upload &amp; Encoding Pipeline" vertex="1">
          <mxGeometry height="22" width="700" x="250" y="47" as="geometry" />
        </mxCell>
        <mxCell id="p3-flow-title" parent="1" style="text;html=1;align=center;fontSize=12;strokeColor=none;fillColor=none;fontStyle=2;" value="Flow: User Upload → Raw Storage → Encoding → Multi-Resolution → CDN" vertex="1">
          <mxGeometry height="22" width="1000" x="100" y="72" as="geometry" />
        </mxCell>
        <mxCell id="p3-user" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;b style=&quot;&quot;&gt;User&lt;/b&gt;&lt;br&gt;(Mobile / Web)&lt;br&gt;Selects video file&lt;/font&gt;" vertex="1">
