        </mxCell>
        <mxCell id="p2-e4" parent="1" style="text;html=1;align=left;fontSize=11;" value="&lt;b&gt;Like&lt;/b&gt;  { likeId, userId, videoId, type: LIKE|DISLIKE, createdAt }" vertex="1">
