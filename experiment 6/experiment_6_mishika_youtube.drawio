        </mxCell>
        <mxCell id="p4-hls1" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• Video split into small .ts (MPEG-TS) segments (2–6 sec each)" vertex="1">
          <mxGeometry height="25" width="475" x="45" y="135" as="geometry" />
        </mxCell>
        <mxCell id="p4-hls2" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• A master .m3u8 playlist lists all quality variants:" vertex="1">
          <mxGeometry height="25" width="475" x="45" y="160" as="geometry" />
        </mxCell>
        <mxCell id="p4-hls4" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• Each quality has its own segment .m3u8 + .ts chunk files" vertex="1">
          <mxGeometry height="25" width="475" x="45" y="188" as="geometry" />
        </mxCell>
        <mxCell id="p4-hls5" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• Supported natively on iOS/Safari; others use HLS.js library" vertex="1">
          <mxGeometry height="25" width="475" x="45" y="220" as="geometry" />
        </mxCell>
        <mxCell id="p4-hls6" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;" value="• Runs over standard HTTP — CDN-friendly, no special infra" vertex="1">
          <mxGeometry height="25" width="475" x="55" y="260" as="geometry" />
        </mxCell>
        <mxCell id="p4-dash-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
