        <mxCell id="p2-e1" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="&lt;b&gt;User&lt;/b&gt;  { userId, name, email, passwordHash, channelId, createdAt }" vertex="1">
