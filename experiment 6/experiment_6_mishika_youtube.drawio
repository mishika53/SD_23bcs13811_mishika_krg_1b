        <mxCell id="p2-api-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="560" width="490" x="560" y="100" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-title" parent="1" style="text;html=1;align=center;fontSize=14;strokeColor=none;fillColor=none;" value="&lt;b&gt;API Endpoints&lt;/b&gt;" vertex="1">
          <mxGeometry height="28" width="470" x="570" y="108" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-upload" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Upload]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="145" as="geometry" />
        </mxCell>
        <mxCell id="p2-a1" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="POST /video/upload   { title, description, tags, file }" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="165" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-stream" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Stream]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="193" as="geometry" />
        </mxCell>
        <mxCell id="p2-a2" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="GET /video/{videoId}/stream?quality=auto|1080p|720p|360p" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p2-a2b" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="   → Returns: HLS .m3u8 manifest" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="237" as="geometry" />
        </mxCell>
        <mxCell id="p2-a2c" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="   → quality=auto: player will use ABR (adaptive bitrate)" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="259" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-like" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Likes]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="300" as="geometry" />
        </mxCell>
        <mxCell id="p2-a3" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="POST /video/{videoId}/like   { type: LIKE|DISLIKE }" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="320" as="geometry" />
        </mxCell>
        <mxCell id="p2-a4" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="DELETE /video/{videoId}/like   (remove like/dislike)" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="342" as="geometry" />
        </mxCell>
        <mxCell id="p2-a5" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="GET /video/{videoId}/likes   → { likeCount, dislikeCount }" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="364" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-cmt" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Comments]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="400" as="geometry" />
        </mxCell>
        <mxCell id="p2-a6" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="POST /video/{videoId}/comment   { text }" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="420" as="geometry" />
        </mxCell>
        <mxCell id="p2-a7" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="GET /video/{videoId}/comments?cursor" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="442" as="geometry" />
        </mxCell>
        <mxCell id="p2-a7b" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="   → Returns: List&lt;Comment&gt; with cursor-based pagination" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="464" as="geometry" />
        </mxCell>
        <mxCell id="p2-a8" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="DELETE /comment/{commentId}" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="486" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-search" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Search]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="522" as="geometry" />
        </mxCell>
        <mxCell id="p2-a9" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="GET /search?q={query}&amp;filter=title|tag|channel" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="542" as="geometry" />
        </mxCell>
        <mxCell id="p2-api-sub" parent="1" style="text;html=1;align=left;fontSize=12;strokeColor=none;fillColor=none;fontStyle=1;" value="&lt;b&gt;[Channel / Subscribe]&lt;/b&gt;" vertex="1">
          <mxGeometry height="22" width="460" x="575" y="568" as="geometry" />
        </mxCell>
        <mxCell id="p2-a10" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="POST /channel/{channelId}/subscribe" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="590" as="geometry" />
        </mxCell>
        <mxCell id="p2-a11" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;fontFamily=Courier New;" value="DELETE /channel/{channelId}/subscribe" vertex="1">
          <mxGeometry height="22" width="460" x="580" y="612" as="geometry" />
        </mxCell>
      </root>
