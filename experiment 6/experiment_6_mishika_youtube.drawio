        <mxCell id="p2-e3" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="&lt;b&gt;VideoSegment&lt;/b&gt;  { segmentId, videoId, resolution," vertex="1">
