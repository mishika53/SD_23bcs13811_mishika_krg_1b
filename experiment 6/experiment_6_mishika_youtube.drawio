        </mxCell>
        <mxCell id="p2-e3b" parent="1" style="text;html=1;align=left;fontSize=11;strokeColor=none;fillColor=none;" value="format: HLS|DASH, cdnUrl, manifestUrl, bitrate }" vertex="1">
