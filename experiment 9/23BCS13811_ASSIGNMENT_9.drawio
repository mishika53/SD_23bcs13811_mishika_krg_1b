        <mxCell id="jgNrpzvnfALyjRSeVGWO-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;rounded=0;fontColor=#333333;" value="API gateway" vertex="1">
          <mxGeometry height="30" width="110" x="524" y="-190" as="geometry" />
