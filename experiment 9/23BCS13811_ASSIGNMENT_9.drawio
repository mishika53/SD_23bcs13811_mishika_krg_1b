              <mxPoint x="1020" y="100" />
              <mxPoint x="1020" y="100" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-79" edge="1" parent="1" source="jgNrpzvnfALyjRSeVGWO-36" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="jgNrpzvnfALyjRSeVGWO-78" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-36" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;rounded=0;fontColor=#333333;" value="Redis distributed lock&lt;div&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;SETNX&lt;/code&gt; means &quot;SET if Not eXists.&quot;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="110" x="970" y="-10" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-38" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;The Core Problem: Race Conditions&lt;/h3&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;Imagine User A and User B both click &quot;Book Seat 12A&quot; at the exact same millisecond. Without any protection:&lt;/p&gt;&lt;ol class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-decimal flex flex-col gap-1 pl-8 mb-3&quot;&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Both requests read: &quot;Seat 12A is available&quot;&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Both proceed to payment&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Both write: &quot;Seat 12A is booked by me&quot;&amp;nbsp;&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Result: &lt;strong&gt;Two people booked the same seat&lt;/strong&gt;&amp;nbsp; .... problem&lt;/li&gt;&lt;/ol&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;This is called a &lt;strong&gt;race condition&lt;/strong&gt;&lt;/p&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;for this i have redis distributed lock means set if not exists&lt;/strong&gt;&lt;/p&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;this will work like&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Redis is &lt;/span&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;single-threaded&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;, meaning it processes commands one at a time. So:&lt;/span&gt;&lt;/p&gt;&lt;ul class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3&quot;&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;User A&#39;s request arrives first ... Redis sets the key.. returns SUCCESS&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;User B&#39;s request arrives 1ms later.... key already exists.. returns FAIL... User B sees &quot;Seat just taken&quot;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="30" width="470" x="1690" y="-120" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-39" parent="1" style="outlineConnect=0;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;shape=mxgraph.aws3.postgre_sql_instance;fillColor=#2E73B8;gradientColor=none;" value="" vertex="1">
          <mxGeometry height="63" width="60" x="990" y="140" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-41" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;rounded=0;fontColor=#333333;" value="Postgre sql&lt;br&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;seats, bookings, shows&lt;/span&gt;&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="120" x="970" y="210" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-42" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" value="">
