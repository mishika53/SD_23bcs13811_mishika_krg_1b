        <mxCell id="jgNrpzvnfALyjRSeVGWO-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#666666;fillColor=#f5f5f5;align=center;verticalAlign=middle;rounded=0;fontColor=#333333;" value="Cdn" vertex="1">
