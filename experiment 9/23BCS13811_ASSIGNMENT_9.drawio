<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram name="Page-1" id="q1mIxlYShcK1l6ETHFit">
    <mxGraphModel dx="1303" dy="1925" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="jgNrpzvnfALyjRSeVGWO-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;FUNCTIONAL REQUIREMENTS&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Search &amp;amp; Discovery:&lt;/strong&gt; Users can search for events by title, city/location, and date.&amp;nbsp;&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Event Detail View:&lt;/strong&gt; Users can view comprehensive event information — description, duration, language, ratings, and a real-time seat map showing available vs. occupied seats.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Booking Execution:&lt;/strong&gt; Users can select a specific seat, enter payment details, and complete a booking. The system must prevent double-booking of the same seat.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Booking Confirmation:&lt;/strong&gt; After a successful booking, the user receives a confirmation with a unique booking ID.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Seat Reservation (Soft Lock):&lt;/strong&gt; When a user selects a seat, it is temporarily held for a short window to complete payment.&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="20" width="490" x="180" y="-890" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 17px;&quot;&gt;NON FUNCTIONAL REQUIREMENTS&lt;/font&gt;&lt;/b&gt;&lt;div&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Scale:&lt;/strong&gt; 100 Million DAU. Assuming 10 search/browse actions per user and 1% conversion, this means 1B read requests/day and 1M booking transactions/day.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;High Availability for Search &amp;amp; Browse:&lt;/strong&gt; The system tolerates eventual consistency here. Stale seat availability data (a few seconds old) is acceptable. We prefer to show results over returning errors. Target: &lt;strong&gt;99.99% uptime&lt;/strong&gt; for read paths.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Strong Consistency for Booking:&lt;/strong&gt; Two users must never book the same seat simultaneously. This requires &lt;strong&gt;ACID transactions&lt;/strong&gt; and distributed locking at the seat level.&lt;/p&gt;&lt;br&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;strong&gt;Low Latency&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="630" x="150" y="-565" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-3" parent="1" style="points=[[0.35,0,0],[0.98,0.51,0],[1,0.71,0],[0.67,1,0],[0,0.795,0],[0,0.65,0]];verticalLabelPosition=bottom;sketch=0;html=1;verticalAlign=top;aspect=fixed;align=center;pointerEvents=1;shape=mxgraph.cisco19.user2;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="" vertex="1">
          <mxGeometry height="50" width="50" x="90" y="-260" as="geometry" />
        </mxCell>
        <mxCell id="jgNrpzvnfALyjRSeVGWO-4" parent="1" style="text;html=1;whiteSpace=wrap;align=center;verticalAlign=middle;rounded=0;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" value="client" vertex="1">
